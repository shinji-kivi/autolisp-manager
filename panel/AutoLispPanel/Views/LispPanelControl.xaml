<UserControl x:Class="AutoLispPanel.Views.LispPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF2D2D30">

    <UserControl.Resources>
        <!-- Expander のトグルボタンスタイル -->
        <Style x:Key="ExpanderToggle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Padding="6,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- 三角アイコン -->
                                <TextBlock x:Name="Arrow"
                                           Grid.Column="0"
                                           Text="&#x25B6;"
                                           Foreground="#FF888888"
                                           FontSize="9"
                                           VerticalAlignment="Center"/>
                                <!-- グループ名 -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DisplayName}"
                                           Foreground="#FFD4D4D4"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <!-- コマンド数バッジ -->
                                <Border Grid.Column="2"
                                        Background="#FF3F3F46"
                                        CornerRadius="7"
                                        Padding="5,1"
                                        Margin="4,0,2,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Commands.Count}"
                                               Foreground="#FF888888"
                                               FontSize="10"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="Text" Value="&#x25BC;"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Arrow" Property="Foreground" Value="#FFD4D4D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- コマンドボタンスタイル -->
        <Style x:Key="CommandButton" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF007ACC"/>
                                <Setter Property="BorderBrush" Value="#FF007ACC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 更新ボタンスタイル -->
        <Style x:Key="RefreshButton" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <TextBlock Grid.Row="0"
                   Text="LISP コマンド"
                   Foreground="#FFD4D4D4"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Margin="8,8,8,4"/>

        <!-- グループ化コマンド一覧 -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="GroupList"
                          Margin="4,0,4,4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander IsExpanded="False">
                            <Expander.Style>
                                <Style TargetType="Expander">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Expander">
                                                <StackPanel>
                                                    <ToggleButton x:Name="HeaderToggle"
                                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                                  Style="{StaticResource ExpanderToggle}"
                                                                  DataContext="{Binding}"/>
                                                    <ContentPresenter x:Name="ExpandContent"
                                                                      Visibility="Collapsed"/>
                                                </StackPanel>
                                                <ControlTemplate.Triggers>
                                                    <Trigger SourceName="HeaderToggle" Property="IsChecked" Value="True">
                                                        <Setter TargetName="ExpandContent" Property="Visibility" Value="Visible"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Expander.Style>
                            <!-- グループ内コマンドボタン -->
                            <ItemsControl ItemsSource="{Binding Commands}"
                                          Margin="16,0,0,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding DisplayLabel}"
                                                ToolTip="{Binding CommandName}"
                                                Click="OnCommandButtonClick"
                                                Margin="0,1"
                                                Height="26"
                                                HorizontalContentAlignment="Left"
                                                Padding="8,0"
                                                FontSize="11"
                                                Background="#FF3F3F46"
                                                Foreground="#FFD4D4D4"
                                                BorderBrush="#FF555555"
                                                BorderThickness="1"
                                                Cursor="Hand"
                                                Style="{StaticResource CommandButton}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ステータス / 更新ボタン -->
        <Grid Grid.Row="2" Margin="4,4,4,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText"
                       Grid.Column="0"
                       Foreground="#FF888888"
                       FontSize="10"
                       VerticalAlignment="Center"
                       Margin="4,0,0,0"
                       TextTrimming="CharacterEllipsis"/>
            <Button Grid.Column="1"
                    Content="更新"
                    Click="OnRefreshClick"
                    Width="44"
                    Height="22"
                    FontSize="10"
                    Background="#FF3F3F46"
                    Foreground="#FFD4D4D4"
                    BorderBrush="#FF555555"
                    BorderThickness="1"
                    Margin="4,0,4,0"
                    Style="{StaticResource RefreshButton}"/>
        </Grid>
    </Grid>
</UserControl>
